<h1>ユーザー登録</h1>

<% if flash[:alert] %>
  <p style="color: red;"><%= flash[:alert] %></p>
<% end %>

<%= form_tag signup_path, method: :post do %>
  <div>
    <label for="email">メールアドレス</label><br>
    <%= email_field_tag :email, params[:email], required: true, autofocus: true %>
  </div>

  <div>
    <label for="password">パスワード</label><br>
    <%= password_field_tag :password, nil, required: true %>
  </div>

  <div>
    <label for="password_confirmation">パスワード（確認）</label><br>
    <%= password_field_tag :password_confirmation, nil, required: true %>
  </div>

  <%= submit_tag "登録" %>
<% end %>

<p><%= link_to "ログインはこちら", login_path %></p>
